# ================================================
# ORION CRM — Environment Variables
# ================================================
# Copie para .env e preencha todos os valores obrigatórios.
# NUNCA commite o arquivo .env no repositório.
# ================================================

# ---- Geral ----
NODE_ENV=production
PORT=4000

# ---- PostgreSQL ----
POSTGRES_PASSWORD=                      # senha forte para o PostgreSQL
DATABASE_URL= #postgres://orion:SUA_SENHA@postgres:5432/orion_db

# ---- Redis ----
REDIS_URL= #redis://redis:6379

# ---- JWT ----
JWT_SECRET=                             # gerar: openssl rand -hex 64
JWT_REFRESH_SECRET=                     # gerar: openssl rand -hex 64 (diferente do acima)

# ---- Operador ORION ----
OPERATOR_WEBHOOK_SECRET=                # gerar: openssl rand -hex 32

# ---- URLs ----
APP_URL=#https://api.seudominio.com.br
FRONTEND_URL=#https://app.seudominio.com.br

# ---- Uploads ----
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=#/app/uploads

# =================================================
# Variáveis reservadas para fases seguintes
# Não bloqueiam o Bloco 1, mas documentam o roadmap.
# =================================================

# ---- Operador / Provisionamento externo ----
OPERATOR_INSTANCE_ID=

# ---- Meta Cloud API (WhatsApp) ----
META_API_TOKEN=                         # Token permanente do WABA
META_PHONE_NUMBER_ID=                   # ID do número no WABA
META_WEBHOOK_VERIFY_TOKEN=              # Token para verificação de webhook
META_APP_SECRET=                        # App Secret para validar X-Hub-Signature-256

# ---- Evolution API (WhatsApp Instance Management) ----
EVOLUTION_URL=                          # Ex.: http://evolution-api:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ---- OpenAI ----
OPENAI_API_KEY=                         # Chave da API OpenAI
ANTHROPIC_API_KEY=                      # Chave da API Anthropic Claude

# ---- Mercado Pago ----
MP_ACCESS_TOKEN=                        # Access Token de produção
MP_WEBHOOK_SECRET=                      # Secret para validar webhooks

# ---- n8n ----
N8N_URL=http://n8n:5678
N8N_API_KEY=                            # Chave da API do n8n
N8N_WEBHOOK_URL=http://n8n:5678/webhook/orion-lead-captured

# ---- SMTP (Email) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                              # Email remetente
SMTP_PASS=                              # Senha de app (Gmail) ou API key
